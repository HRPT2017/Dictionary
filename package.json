{
  "name": "language",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "main": "dist/main.js",
  "build": {
    "appId": "com.example.myapp",
    "productName": "MyApp",
    "files": [
      "dist/**/*",
      "package.json",
      "src/electron/preload.js"
    ],
    "win": {
      "target": "nsis"
    },
      "asarUnpack": [
    "preload.js"
  ]
  },
  "scripts": {
    "dev:react": "vite",
    "dev:electron": "electron .",
    "build": "tsc -b && vite build && esbuild src/electron/main.js --bundle --platform=node --format=cjs --external:electron --outfile=dist/main.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@capacitor/filesystem": "^7.1.4",
    "@capacitor/network": "^7.0.2",
    "@supabase/supabase-js": "^2.78.0",
    "@tailwindcss/vite": "^4.1.16",
    "axios": "^1.13.0",
    "flowbite-react": "^0.12.10",
    "papaparse": "^5.5.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.9.5",
    "tailwindcss": "^4.1.16",
    "uuid": "^13.0.0",
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4",
    "@electron-forge/cli": "^7.10.2",
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.6.0",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^39.0.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.12",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7"
  }
}
